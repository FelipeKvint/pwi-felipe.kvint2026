programa
{
	
	funcao inicio()
	{
	real A, B, C, soma, media


	escreva("Digite o valor de A: ")
	leia(A)

	escreva("Digite o valor de B: ")
	leia(B)

	escreva("Digite o valor de C: ")
	leia(C)

	soma=A+B+C
	media=soma/3

	escreva("Soma: ",soma)
	escreva(" Media: ",media)
	
       

		
	}
}
